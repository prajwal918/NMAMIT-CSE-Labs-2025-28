#!/usr/bin/perl
print "Sum of digits through command line arguments\n";

if ($#ARGV < 0) {
    print "Enter valid numbers as command line arguments\n";
    exit;
}

foreach $num (@ARGV) {
    if ($num !~ /^\d+$/) {
        print "Invalid number: $num\n";
        next;
    }

    $sum = 0;
    $a = $num;

    until ($num == 0) {
        $y = $num % 10;
        $sum = $sum + $y;
        $num = int($num / 10);
    }

    print "Sum of digits in $a is: $sum\n";
}
